@echo off
chcp 65001 >nul
title 夜乃樱桌宠

:: ================================================================
::  启动.bat — 一键启动夜乃樱桌宠
:: ================================================================
::
::  功能：直接启动桌宠，无需打开终端或 PowerShell
::  用法：双击即可
::  前置条件：已安装 Node.js 并执行过 npm install
::
::  如果是首次使用，请先打开「第一次启动必点」文件夹，
::  按顺序双击 setup.bat → run_dev.bat
:: ================================================================

cd /d "%~dp0"
echo 🚀 启动夜乃樱桌宠...
npm run dev
echo.
pause