@echo off
chcp 65001 >nul
title 夜乃樱桌宠
color 0A

:: ================================================================
::  启动.bat — 一键启动夜乃樱桌宠
:: ================================================================
::
::  用法：双击即可启动桌宠
::  前置条件：已执行过 setup.bat 完成安装
:: ================================================================

cls
echo.
echo  ╔═══════════════════════════════════════╗
echo  ║     🚀 夜乃樱桌宠 正在启动...         ║
echo  ╚═══════════════════════════════════════╝
echo.

cd /d "%~dp0"
echo  项目目录: %CD%
echo.
echo  ⚡ 启动中，首次加载语音模型可能较慢...
echo  ⚡ 按 Ctrl+C 可关闭桌宠
echo.
npm run dev
echo.
echo  桌宠已关闭。
pause