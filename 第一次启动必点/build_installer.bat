@echo off
chcp 65001 >nul
title 夜乃樱桌宠 — 打包安装程序

:: ================================================================
::  build_installer.bat — 打包桌宠为安装程序
:: ================================================================
::
::  功能：将项目打包为 .exe 安装包，用于分发
::
::  用法：双击运行（需先执行 setup.bat）
::  输出：dist\my-desktop-pet-1.0.0-setup.exe
::
::  打包内容：
::    - Electron 运行时（约 200 MB）
::    - 立绘 138 张 + 参考音频
::    - 不包含 GPT-SoVITS（需单独下载，约 18 GB）
::
::  发布给朋友时：
::    1. 将生成的 .exe 发给朋友
::    2. 朋友安装后需自行配置 GPT-SoVITS 路径
::    3. 朋友首次使用需在「设置 → API 设置」填入 Key
:: ================================================================

cd /d "%~dp0夜乃樱桌宠_项目源码"
echo 📦 正在打包，请勿关闭此窗口...
call npm run build:win
echo.
if %errorlevel% equ 0 (
    echo ✅ 打包成功！
    echo 安装包: %CD%\dist\my-desktop-pet-1.0.0-setup.exe
) else (
    echo ❌ 打包失败
    echo 常见原因：依赖未安装 / 磁盘空间不足 / 权限不足
)
echo.
pause