@echo off
chcp 65001 >nul
title 夜乃樱桌宠 — 开发模式

:: ================================================================
::  run_dev.bat — 启动夜乃樱桌宠（开发模式）
:: ================================================================
::
::  功能：以开发模式运行桌宠，支持热重载
::       修改源码后自动刷新，终端显示调试日志
::
::  用法：双击运行（需先执行 setup.bat）
::  退出：在桌宠窗口按 Esc 或 Q，或关闭 CMD 窗口
::
::  注意：
::    - 首次启动加载语音模型需 30 秒~2 分钟
::    - 开发模式下所有 console.log 会显示在此窗口
::    - 按 Ctrl+C 可强制关闭
:: ================================================================

cd /d "%~dp0夜乃樱桌宠_项目源码"
echo 🚀 启动夜乃樱桌宠...
echo.
npm run dev
echo.
pause