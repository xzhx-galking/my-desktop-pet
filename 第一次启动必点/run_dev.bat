@echo off
chcp 65001 >nul
title 夜乃樱桌宠 — 开发模式
color 0A

:: ================================================================
::  run_dev.bat — 启动夜乃樱桌宠（开发模式）
:: ================================================================
::
::  功能：以开发模式运行桌宠，修改源码后自动刷新
::  用法：双击运行（需先执行 setup.bat）
::  退出：在桌宠窗口按 Esc 或 Q
:: ================================================================

cls
echo.
echo  ╔═══════════════════════════════════════╗
echo  ║     🚀 夜乃樱桌宠 正在启动...         ║
echo  ╚═══════════════════════════════════════╝
echo.

cd /d "%~dp0.."
echo  项目目录: %CD%
echo.
echo  ⚡ 首次加载语音模型可能较慢（30秒~2分钟）
echo  ⚡ 按 Ctrl+C 可关闭
echo.
npm run dev
echo.
pause